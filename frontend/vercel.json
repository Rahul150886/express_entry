{
  "version": 2,
  "name": "express-entry-frontend",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": "@vite-api-url"
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "max-age=31536000, immutable"
      },
      "dest": "/assets/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://express-entry-production.up.railway.app/api/$1"
    },
    {
      "src": "/(.*)",
      "methods": ["GET"],
      "dest": "/index.html"
    }
  ],
  "framework": "vite"
}
