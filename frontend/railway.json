{
  "build": {
    "builder": "dockerfile",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "numReplicas": 1,
    "startupTimeout": 300,
    "ports": [
      {
        "port": 80,
        "protocol": "TCP"
      }
    ]
  }
}
