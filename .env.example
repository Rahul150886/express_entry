# ========== DATABASE ==========
DATABASE_URL=postgresql://user:password@localhost:5432/express_entry

# ========== REDIS ==========
REDIS_URL=redis://localhost:6379/0

# ========== AI & AZURE ==========
OPENAI_API_KEY=your-openai-key
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_ACCOUNT_KEY=your-storage-key
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-key
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-region.api.cognitive.microsoft.com/
AZURE_COGNITIVESERVICES_SPEECH_KEY=your-speech-key
AZURE_COGNITIVESERVICES_SPEECH_REGION=your-region

# ========== AUTH ==========
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== FRONTEND ==========
VITE_API_BASE_URL=http://localhost:8000/api

# ========== CORS ==========
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ========== NOTIFICATIONS ==========
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ========== CELERY & BACKGROUND JOBS ==========
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ========== ENVIRONMENT ==========
ENVIRONMENT=production
DEBUG=false

# ========== LOGGING ==========
LOG_LEVEL=INFO
