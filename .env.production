# Production Environment Variables for Railway
# These should be set in Railway Dashboard → Your Service → Variables

# ========== DATABASE (Set by Railway PostgreSQL service) ==========
# This is auto-generated when you add PostgreSQL to Railway
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@railway-db-host:5432/railway

# ========== REDIS (Optional - set if you add Redis service) ==========
REDIS_URL=redis://user:password@railway-redis-host:6379/0

# ========== API & CORS ==========
API_URL=https://your-railway-app-url.onrender.com
FRONTEND_URL=https://your-frontend-url.onrender.com
CORS_ORIGINS=["https://your-frontend-url.onrender.com"]

# ========== ENVIRONMENT ==========
ENVIRONMENT=production
DEBUG=false

# ========== AUTH & SECURITY ==========
SECRET_KEY=your-secret-key-change-this-to-something-secure
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== AI & AZURE (Optional - add if you use these services) ==========
OPENAI_API_KEY=sk-xxx
AZURE_STORAGE_ACCOUNT_NAME=your-storage
AZURE_STORAGE_ACCOUNT_KEY=your-key
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-key
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-region.api.cognitive.microsoft.com/

# ========== NOTIFICATIONS (Optional) ==========
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ========== LOGGING ==========
LOG_LEVEL=INFO
SENTRY_DSN=https://your-sentry-url

# ========== CELERY/BACKGROUND JOBS (Optional) ==========
CELERY_BROKER_URL=redis://your-redis:6379/1
CELERY_RESULT_BACKEND=redis://your-redis:6379/2
